# ============================================================
# Universal API Hub - Root .gitignore
# ============================================================

# ── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Environment ──────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.development

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.~lock.*

# ── Build outputs ────────────────────────────────────────────
dist/
build/
out/
.next/
*.tsbuildinfo

# ── Coverage ─────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Temporary ────────────────────────────────────────────────
tmp/
temp/
*.tmp

# ── Docker ───────────────────────────────────────────────────
*.pid
*.seed
*.pid.lock

# ── Redis ────────────────────────────────────────────────────
dump.rdb

# ── PostgreSQL ──────────────────────────────────────────────
*.sqlite
*.db
*.sqlite3

# ── Backend specific ─────────────────────────────────────────
backend/logs/
backend/.env
backend/node_modules/
backend/package-lock.json

# ── Frontend specific ────────────────────────────────────────
frontend/dist/
frontend/.env.local
frontend/node_modules/
frontend/package-lock.json

# ── Misc ─────────────────────────────────────────────────────
*.pem
*.key
*.crt
.cache/
.eslintcache